# ── Autenticação ──────────────────────────────────────────────────────────────
# Chave usada pelo frontend para POST e DELETE /registrations
API_KEY=troque-por-uma-chave-segura

# Chave separada para acesso administrativo (GET /registrations)
ADMIN_API_KEY=troque-por-outra-chave-segura

# ── Infra ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./data/riobus.db

# ── APIs externas ─────────────────────────────────────────────────────────────
# Conta gratuita: https://openrouteservice.org
ORS_API_KEY=

# ── SMTP (Mailtrap sandbox para dev) ─────────────────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=alertas@riobus.dev

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Embutida no bundle em build-time — use o mesmo valor de API_KEY.
# Atenção: variáveis VITE_* ficam visíveis no código transpilado do browser.
VITE_API_KEY=mesma-chave-que-API_KEY
